---
import ManualScroller from '../components/ManualScroller.astro';
import allModules from '../data/modules.json';
import '../styles/global.css';
let base = import.meta.env.BASE_URL;
if (!base.endsWith('/')) base += '/';

const modules = allModules.filter((m) => m.collection === 'sands');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV funk Manual — Sands</title>
    <meta name="description" content="CV funk Sands 2026 collection  - IN DEVELOPMENT" />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <div class="brand">
          <a href={import.meta.env.BASE_URL}>CV funk Manual</a>
          <div class="brand-sub">Sands Collection</div>
        </div>

        <nav class="header-actions">
          <a class="btn" href="https://github.com/codygeary/CVfunk-Modules" target="_blank" rel="noreferrer">GitHub</a>
          <a class="btn" href="https://github.com/codygeary/CVfunk-Modules/blob/main/img/CV_funk_PRO_Manual.pdf" target="_blank" rel="noreferrer">PDF</a>
          <!-- Update this to your store / product link -->
          <a class="btn" href="#" rel="noreferrer">Buy</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
        <ManualScroller modules={modules} currentCollection="sands" />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div>© {new Date().getFullYear()} CV funk / Cody Geary</div>
        <div class="muted">Built with Astro.</div>
      </div>
    </footer>
  </body>
</html>
