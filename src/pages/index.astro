---
import ManualScroller from '../components/ManualScroller.astro';
import modules from '../data/modules.json';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV funk Manual</title>
    <meta name="description" content="CV funk modules manual for VCV Rack." />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <div class="brand">
          <div class="brand-title">CV funk Manual</div>
          <div class="brand-sub">Module Collection for VCV Rack</div>
        </div>

        <nav class="header-actions">
          <a class="btn" href="https://github.com/codygeary/CVfunk-Modules" target="_blank" rel="noreferrer">GitHub</a>
          <a class="btn" href="https://github.com/codygeary/CVfunk-Modules/blob/main/img/CV_funk_Manual.pdf" target="_blank" rel="noreferrer">PDF</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <ManualScroller modules={modules} />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div>© {new Date().getFullYear()} CV funk / Cody Geary</div>
        <div class="muted">Built with Astro. Static hosting friendly.</div>
      </div>
    </footer>
  </body>
</html>
