---
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV funk Manual</title>
    <meta name="description" content="CV funk modules manuals for VCV Rack." />

    <style>
      /* ---- Landing-only styles ---- */

      .landing-title{
        text-align:center;
      }

      .landing-sub{
        max-width:78ch;
        margin:10px auto 0;
        text-align:justify;
        text-justify:inter-word;
      }

      /* Hero: attention-grabbing but capped so it doesn't eat the whole screen */
      .landing-hero{
        margin:28px auto 0;
        max-width:980px;
        max-height:62vh;
        border:1px solid var(--line);
        border-radius:var(--radius);
        background:color-mix(in srgb, var(--bg) 94%, var(--card));
        box-shadow:var(--shadow);
        overflow:hidden;
      }
      .landing-hero img{
        display:block;
        width:100%;
        height:auto;
        max-height:62vh;
        object-fit:cover;
        object-position:center top;
      }

      /* About section */
      .about{
        margin:22px auto 0;
        max-width:980px;
        border:1px solid var(--line);
        border-radius:var(--radius);
        background:color-mix(in srgb, var(--bg) 94%, var(--card));
        box-shadow:var(--shadow);
        padding:16px;
      }
      .about h2{
        margin:0 0 10px;
        font-size:13px;
        letter-spacing:.12em;
        text-transform:uppercase;
        color:var(--muted);
      }
      .about-inner{
        display:grid;
        grid-template-columns:88px 1fr;
        gap:14px;
        align-items:center;
      }
      .about-portrait{
        width:88px;
        height:88px;
        border-radius:999px;
        border:1px solid var(--line);
        object-fit:cover;
        background:var(--card);
      }
      .about p{
        margin:0;
        line-height:1.55;
      }

      /* Collections nav sits above cards with a label */
      .collections-label{
        font-size:13px;
        letter-spacing:.1em;
        text-transform:uppercase;
        color:var(--muted);
        margin:28px 0 10px;
      }

      @media (max-width:600px){
        .about-inner{
          grid-template-columns:1fr;
          justify-items:center;
          text-align:center;
        }
        .landing-sub{
          text-align:left;
        }
        .landing-hero{
          max-height:45vw;
        }
      }
    </style>
  </head>

  <!-- is-landing disables the overflow:hidden body lock used by manual pages -->
  <body class="is-landing">
    <header class="site-header">
      <div class="wrap header-inner">
        <div class="brand">
          <div class="brand-title">CV funk Manual</div>
          <div class="brand-sub">Module collections for VCV Rack</div>
        </div>

        <nav class="header-actions">
          <a class="btn" href="https://github.com/codygeary/CVfunk-Modules" target="_blank" rel="noreferrer">GitHub</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <section class="landing">
        <h1 class="landing-title">CV funk Module Collection for VCV Rack</h1>

        <p class="landing-sub muted">
          Explore the CV funk module collection for VCV Rack: a set of patch-programmable tools for modulation, sequencing, and control.
          The goal is fast, musical results from simple inputs, with enough depth to stay interesting as patches grow.
        </p>

        <p class="collections-label">Collections</p>

        <div class="cards">
          <a class="card" href="/free">
            <div class="card-body">
              <div class="card-title">Free Modules</div>
              <div class="card-text">Core CV funk modules</div>
            </div>
            <span class="card-arrow" aria-hidden="true">→</span>
          </a>

          <a class="card" href="/chord-caster">
            <div class="card-body">
              <div class="card-title">Chord Caster</div>
              <div class="card-text">Premium semimodular system</div>
            </div>
            <span class="card-arrow" aria-hidden="true">→</span>
          </a>

          <a class="card" href="/modulations">
            <div class="card-body">
              <div class="card-title">Modulations</div>
              <div class="card-text">Premium polyphonic workflow</div>
            </div>
            <span class="card-arrow" aria-hidden="true">→</span>
          </a>

          <a class="card" href="/sands">
            <div class="card-body">
              <div class="card-title">Sands</div>
              <div class="card-text">Premium 2026 collection, in development</div>
            </div>
            <span class="card-arrow" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="landing-hero" aria-hidden="true">
          <img src="/img/landing-hero.png" alt="" loading="lazy" decoding="async" />
        </div>

        <section class="about">
          <h2>About</h2>
          <div class="about-inner">
            <img class="about-portrait" src="/img/cody-portrait.jpg" alt="Portrait of Cody Geary" loading="lazy" decoding="async" />
            <p class="muted">
              Cody Geary builds CV funk modules for VCV Rack, focused on patch-programmable control, modulation, and performance-friendly workflows.
              This site is a compact manual for the collections, with a scrollable reference format designed for patching at the rack.
            </p>
          </div>
        </section>
      </section>
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div>© {new Date().getFullYear()} CV funk / Cody Geary</div>
      </div>
    </footer>

    <script>
      // Restore theme preference on landing page too
      (() => {
        const saved = localStorage.getItem('cvfunk_theme');
        if (saved === 'dark') document.documentElement.classList.add('dark');
      })();
    </script>
  </body>
</html>
