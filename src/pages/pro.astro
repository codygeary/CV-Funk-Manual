---
import ManualScroller from '../components/ManualScroller.astro';
import allModules from '../data/modules.json';
import '../styles/global.css';

const modules = allModules.filter((m) => m.collection === 'pro');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>CV funk Manual — Pro</title>
    <meta name="description" content="CV funk Pro collection manual for VCV Rack." />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap header-inner">
        <div class="brand">
          <a class="brand-title" href="/">CV funk Manual</a>
          <div class="brand-sub">Pro Collection</div>
        </div>

        <nav class="header-actions">
          <a class="btn" href="https://github.com/codygeary/CVfunk-Modules" target="_blank" rel="noreferrer">GitHub</a>
          <!-- Update this to your store / product link -->
          <a class="btn" href="#" rel="noreferrer">Buy</a>
        </nav>
      </div>
    </header>

    <main class="wrap">
      <ManualScroller modules={modules} currentCollection="pro" />
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div>© {new Date().getFullYear()} CV funk / Cody Geary</div>
        <div class="muted">Built with Astro. Static hosting friendly.</div>
      </div>
    </footer>
  </body>
</html>
