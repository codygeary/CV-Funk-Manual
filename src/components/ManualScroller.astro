---
const { modules, currentCollection = 'free' } = Astro.props;

/**
 * modules: [
 *  { name, slug, tagline, panelImage, sections: { panelMap, basicUse, patching } }
 * ]
 */
---

<section class="manual">
  <aside class="manual-left">
    <div class="sticky">
      <div class="left-top">
        <nav class="collections" aria-label="Collections">
          <a class={['tab', currentCollection === 'free' && 'active'].filter(Boolean).join(' ')} href="/free">Free</a>
          <a class={['tab', currentCollection === 'modulations' && 'active'].filter(Boolean).join(' ')} href="/modulations">Modulations</a>
          <a class={['tab', currentCollection === 'chord-caster' && 'active'].filter(Boolean).join(' ')} href="/chord-caster">Chord Caster</a>
        </nav>

        <div class="picker">
          <label class="picker-label" for="moduleJump">Jump</label>
          <select id="moduleJump" class="picker-select">
            {modules.map((m) => <option value={m.slug}>{m.name}</option>)}
          </select>
        </div>

        <div class="toggle">
          <button id="themeToggle" class="btn" type="button" aria-label="Toggle theme">Theme</button>
        </div>
      </div>

      <div class="panel-frame">
        <img id="panelImg" class="panel-img" src={modules[0].panelImage} alt={modules[0].name} loading="eager" />
        <div id="panelOverlay" class="panel-overlay">
          <div id="panelTitle" class="panel-title">{modules[0].name}</div>
          <div id="panelTagline" class="panel-tagline">{modules[0].tagline}</div>
        </div>
      </div>

      <div class="hint muted">Scroll on the right to advance modules.</div>
    </div>
  </aside>

  <div class="manual-right">
    {modules.map((m) => (
      <article id={m.slug} class="module" data-slug={m.slug} data-name={m.name} data-tagline={m.tagline} data-img={m.panelImage}>
        <header class="module-header">
          <h2 class="module-title">{m.name}</h2>
          <p class="module-tagline">{m.tagline}</p>
        </header>

        <section class="module-section">
          <h3>Panel map</h3>
          <div class="prose"><pre>{m.sections.panelMap}</pre></div>
        </section>

        {m.sections.basicUse?.trim() ? (
          <section class="module-section">
            <h3>Basic use</h3>
            <div class="prose"><pre>{m.sections.basicUse}</pre></div>
          </section>
        ) : null}

        {m.sections.patching?.trim() ? (
          <section class="module-section">
            <h3>Patching suggestions</h3>
            <div class="prose"><pre>{m.sections.patching}</pre></div>
          </section>
        ) : null}

        <div class="module-divider"></div>
      </article>
    ))}
  </div>

  <script>
    const modules = Array.from(document.querySelectorAll('.module'));
    const panelImg = document.getElementById('panelImg');
    const panelTitle = document.getElementById('panelTitle');
    const panelTagline = document.getElementById('panelTagline');
    const moduleJump = document.getElementById('moduleJump');
    const themeToggle = document.getElementById('themeToggle');

    function toDarkVariant(src) {
      // Supports .png/.jpg/.jpeg/.webp
      return src.replace(/\.(png|jpg|jpeg|webp)$/i, '-dark.$1');
    }

    function setPanelImage(lightSrc, name) {
      const isDark = document.documentElement.classList.contains('dark');
      const desired = isDark ? toDarkVariant(lightSrc) : lightSrc;

      // Try desired first; if missing, fall back to light.
      panelImg.onerror = () => {
        if (panelImg.src.endsWith(toDarkVariant(lightSrc))) {
          panelImg.onerror = null;
          panelImg.src = lightSrc;
        }
      };
      panelImg.src = desired;
      panelImg.alt = name;
    }

    function setActive(moduleEl) {
      if (!moduleEl) return;
      setPanelImage(moduleEl.dataset.img, moduleEl.dataset.name);
      panelTitle.textContent = moduleEl.dataset.name;
      panelTagline.textContent = moduleEl.dataset.tagline;
      moduleJump.value = moduleEl.dataset.slug;
      modules.forEach((el) => el.classList.toggle('active', el === moduleEl));
    }

    // Scroll spy: pick the module whose top is closest to the viewport top.
    const io = new IntersectionObserver((entries) => {
      const visible = entries
        .filter(e => e.isIntersecting)
        .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (visible) setActive(visible.target);
    }, { root: null, threshold: [0.25, 0.5, 0.75] });

    modules.forEach((m) => io.observe(m));

    moduleJump.addEventListener('change', (e) => {
      const slug = e.target.value;
      const el = document.getElementById(slug);
      if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    // Theme toggle (simple): toggles a class on <html>.
    themeToggle.addEventListener('click', () => {
      const html = document.documentElement;
      html.classList.toggle('dark');
      localStorage.setItem('cvfunk_theme', html.classList.contains('dark') ? 'dark' : 'light');

      // Refresh left image to match theme.
      const active = document.querySelector('.module.active') || modules[0];
      setActive(active);
    });

    // Restore theme
    (() => {
      const saved = localStorage.getItem('cvfunk_theme');
      if (saved === 'dark') document.documentElement.classList.add('dark');
    })();

    // Initialize
    setActive(modules[0]);
  </script>
</section>
