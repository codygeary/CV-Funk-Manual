---
const { modules, currentCollection = 'free' } = Astro.props;

/**
 * modules: [
 *  { name, slug, tagline, panelImage, sections: { panelMap, basicUse, patching } }
 * ]
 */
---

<section class="manual">
  <aside class="manual-left">
    <div class="sticky">
      <div class="left-top">
        <nav class="collections" aria-label="Collections">
          <a class={['tab', currentCollection === 'free'         && 'active'].filter(Boolean).join(' ')} href={`${import.meta.env.BASE_URL}`}>Free</a>
          <a class={['tab', currentCollection === 'modulations'  && 'active'].filter(Boolean).join(' ')} href={`${import.meta.env.BASE_URL}`}>Modulations</a>
          <a class={['tab', currentCollection === 'chord-caster' && 'active'].filter(Boolean).join(' ')} href={`${import.meta.env.BASE_URL}`}>Chord Caster</a>
          <a class={['tab', currentCollection === 'sands'        && 'active'].filter(Boolean).join(' ')} href={`${import.meta.env.BASE_URL}`}>Sands</a>
        </nav>

        <div class="picker">
          <label class="picker-label" for="moduleJump">Jump</label>
          <select id="moduleJump" class="picker-select">
            {modules.map((m) => <option value={m.slug}>{m.name}</option>)}
          </select>
        </div>

        <div class="toggle">
          <button id="themeToggle" class="btn" type="button" aria-label="Toggle theme">Theme</button>
        </div>
      </div>

      <div class="panel-frame">
        <img id="panelImg" class="panel-img" src={modules[0].panelImage} alt={modules[0].name} loading="eager" />
        <div id="panelOverlay" class="panel-overlay">
          <div id="panelTitle" class="panel-title">{modules[0].name}</div>
          <div id="panelTagline" class="panel-tagline">{modules[0].tagline}</div>
        </div>
      </div>

      <div class="hint muted desktop-only scroll-hint" aria-hidden="true">
        Scroll on the right to advance modules.
      </div>
    </div>
  </aside>

  <div class="manual-right">
    {modules.map((m) => (
      <article
        id={m.slug}
        class="module"
        data-slug={m.slug}
        data-name={m.name}
        data-tagline={m.tagline}
        data-img={m.panelImage}
      >
        <header class="module-header">
          <h2 class="module-title">{m.name}</h2>
          <p class="module-tagline">{m.tagline}</p>
        </header>

        <section class="module-section">
          <h3>Panel map</h3>
          <div class="prose"><pre>{m.sections.panelMap}</pre></div>
        </section>

        {m.sections.basicUse?.trim() ? (
          <section class="module-section">
            <h3>Basic use</h3>
            <div class="prose"><pre>{m.sections.basicUse}</pre></div>
          </section>
        ) : null}

        {m.sections.patching?.trim() ? (
          <section class="module-section">
            <h3>Patching suggestions</h3>
            <div class="prose"><pre>{m.sections.patching}</pre></div>
          </section>
        ) : null}

        <div class="module-divider"></div>
      </article>
    ))}
  </div>

  <script>
    const modules = Array.from(document.querySelectorAll('.module'));
    const panelImg    = document.getElementById('panelImg')    as HTMLImageElement;
    const panelTitle  = document.getElementById('panelTitle')  as HTMLElement;
    const panelTagline = document.getElementById('panelTagline') as HTMLElement;
    const moduleJump  = document.getElementById('moduleJump')  as HTMLSelectElement;
    const themeToggle = document.getElementById('themeToggle') as HTMLButtonElement;

    // ---- Theme helpers ----

    function toDarkVariant(src: string) {
      return src.replace(/\.(png|jpg|jpeg|webp)$/i, '-dark.');
    }

    function setPanelImage(lightSrc: string, name: string) {
      const isDark = document.documentElement.classList.contains('dark');
      const desired = isDark ? toDarkVariant(lightSrc) : lightSrc;

      panelImg.onerror = () => {
        if (panelImg.src.endsWith(toDarkVariant(lightSrc))) {
          panelImg.onerror = null;
          panelImg.src = lightSrc;
        }
      };
      panelImg.src = desired;
      panelImg.alt = name;
    }

    // ---- Active module ----

    function setActive(moduleEl: Element | null) {
      if (!moduleEl) return;
      const el = moduleEl as HTMLElement;
      setPanelImage(el.dataset.img!, el.dataset.name!);
      panelTitle.textContent  = el.dataset.name!;
      panelTagline.textContent = el.dataset.tagline!;
      moduleJump.value = el.dataset.slug!;
      modules.forEach((m) => m.classList.toggle('active', m === moduleEl));
    }

    // ---- Scroll spy ----

    const header = document.querySelector('.site-header');
    const manualRight = document.querySelector('.manual-right') as HTMLElement;

    function getScroller(): HTMLElement | Window {
      if (manualRight && manualRight.scrollHeight > manualRight.clientHeight + 2) return manualRight;
      return window;
    }

    let scroller = getScroller();

    function headerHeight() {
      return header ? (header as HTMLElement).getBoundingClientRect().height : 0;
    }

    function contentTop() {
      return headerHeight() + 12;
    }

    function pickByClosestTop() {
      const topRef = contentTop();
      const scrollerTop = (scroller === window) ? 0 : (scroller as HTMLElement).getBoundingClientRect().top;

      let best: Element | null = null;
      let bestDist = Infinity;

      for (const el of modules) {
        const r = el.getBoundingClientRect();
        const dist = Math.abs(r.top - (scrollerTop + topRef));

        const viewBottom = (scroller === window)
          ? window.innerHeight
          : (scroller as HTMLElement).getBoundingClientRect().bottom;

        if (r.top > viewBottom + 40) continue;
        if (dist < bestDist) { bestDist = dist; best = el; }
      }

      if (best) setActive(best);
    }

    // Intersection observer + scroll listener — rebuilt on resize
    function setupSpy() {
      scroller = getScroller();

      if ((window as any).__cvfunkIO) {
        try { (window as any).__cvfunkIO.disconnect(); } catch {}
      }
      if ((window as any).__cvfunkOnScroll && (window as any).__cvfunkScrollEl) {
        (window as any).__cvfunkScrollEl.removeEventListener('scroll', (window as any).__cvfunkOnScroll);
      }

      const rootEl = (scroller === window) ? null : scroller as HTMLElement;

      const io = new IntersectionObserver(
        () => pickByClosestTop(),
        {
          root: rootEl,
          rootMargin: `-${contentTop()}px 0px -70% 0px`,
          threshold: [0, 0.01],
        }
      );

      (window as any).__cvfunkIO = io;
      modules.forEach((m) => io.observe(m));

      const onScroll = () => pickByClosestTop();
      const scrollEl = (scroller === window) ? window : scroller;

      scrollEl.addEventListener('scroll', onScroll, { passive: true });
      (window as any).__cvfunkOnScroll = onScroll;
      (window as any).__cvfunkScrollEl = scrollEl;

      pickByClosestTop();
    }

    setupSpy();
    window.addEventListener('resize', setupSpy, { passive: true });

    // ---- Jump select ----

    moduleJump.addEventListener('change', (e) => {
      const slug = (e.target as HTMLSelectElement).value;
      const el = document.getElementById(slug);
      if (!el) return;

      const sc = getScroller();
      if (sc === window) {
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      } else {
        (sc as HTMLElement).scrollTo({ top: el.offsetTop, behavior: 'smooth' });
      }
    });

    // ---- Theme toggle ----

    themeToggle.addEventListener('click', () => {
      const html = document.documentElement;
      html.classList.toggle('dark');
      localStorage.setItem('cvfunk_theme', html.classList.contains('dark') ? 'dark' : 'light');

      const active = document.querySelector('.module.active') || modules[0];
      setActive(active);
    });

    // Restore saved theme
    (() => {
      const saved = localStorage.getItem('cvfunk_theme');
      if (saved === 'dark') document.documentElement.classList.add('dark');
    })();

    // Init
    setActive(modules[0]);
  </script>
</section>
